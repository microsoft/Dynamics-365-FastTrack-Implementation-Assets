// ========================================
// Performance Baseline Deviation
// ========================================
/*
let Baseline = Perf
| where TimeGenerated between (ago(7d) .. ago(1d))
| where ObjectName == "Processor" and CounterName == "% Processor Time" and InstanceName == "_Total"
| summarize BaselineAvg = avg(CounterValue), BaselineStdDev = stdev(CounterValue) by Computer;

Perf
| where TimeGenerated > ago(TimeRange)
| where ObjectName == "Processor" and CounterName == "% Processor Time" and InstanceName == "_Total"
| summarize CurrentAvg = avg(CounterValue) by Computer
| join kind=inner (Baseline) on Computer
| extend 
    Deviation = CurrentAvg - BaselineAvg,
    DeviationPercent = round(100.0 * (CurrentAvg - BaselineAvg) / BaselineAvg, 2),
    IsAnomaly = abs(CurrentAvg - BaselineAvg) > (2 * BaselineStdDev)
| project 
    Device = Computer,
    CurrentAvg = round(CurrentAvg, 2),
    BaselineAvg = round(BaselineAvg, 2),
    Deviation = round(Deviation, 2),
    DeviationPercent,
    IsAnomaly
| order by abs(Deviation) desc
*/

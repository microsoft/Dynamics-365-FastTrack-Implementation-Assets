		<resources culture="en-US">
			<stringTable>
        <string id="Channel.Microsoft-Dynamics-AX-XppExecutionTraces/Debug" value="Debug">
        </string>
        <string id="level.Verbose" value="Verbose">
				</string>
				<string id="Microsoft-Dynamics-AX-XppExecutionTraces.event.24502.message" value="X++ Sequence Point">

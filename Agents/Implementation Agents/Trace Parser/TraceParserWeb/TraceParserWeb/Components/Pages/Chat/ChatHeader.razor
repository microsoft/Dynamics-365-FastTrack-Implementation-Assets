@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims

<div class="chat-header-container">
    <div class="chat-header-inner">
        <div class="chat-header-left">
            <!-- App Logo -->
            <img src="TraceParserAgent_Logo_Primary.svg" alt="Trace Parser Agent" class="microsoft-logo" width="28" height="28" />
            <div class="chat-header-title-container">
                <h1 class="chat-header-title">Trace Parser Agent Web</h1>
                @if (!string.IsNullOrEmpty(ActiveAgentName))
                {
                    <span class="active-agent-name">@ActiveAgentName</span>
                }
            </div>
        </div>
        <div class="chat-header-controls">
            @if (CurrentPage == "chat")
            {
                <!-- Show Reasoning Toggle (Chat only) -->
                <label class="toggle-label" title="Show agent reasoning and informative messages">
                    <span class="toggle-text">Persist reasoning</span>
                    <div class="toggle-switch @(ShowInformativeMessages ? "toggle-on" : "")" @onclick="OnToggleInformativeMessages">
                        <div class="toggle-knob"></div>
                    </div>
                </label>
            }

            @if (CurrentPage != "chat")
            {
                <!-- Back to Chat link -->
                <a href="/" class="analysis-nav-btn" title="Back to Chat">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5"
                         stroke="currentColor" width="16" height="16">
                        <path stroke-linecap="round" stroke-linejoin="round"
                              d="M20.25 8.511c.884.284 1.5 1.128 1.5 2.097v4.286c0 1.136-.847 2.1-1.98 2.193-.34.027-.68.052-1.02.072v3.091l-3-3c-1.354 0-2.694-.055-4.02-.163a2.115 2.115 0 01-.825-.242m9.345-8.334a2.126 2.126 0 00-.476-.095 48.64 48.64 0 00-8.048 0c-1.131.094-1.976 1.057-1.976 2.192v4.286c0 .837.46 1.58 1.155 1.951m9.345-8.334V6.637c0-1.621-1.152-3.026-2.76-3.235A48.455 48.455 0 0011.25 3c-2.115 0-4.198.137-6.24.402-1.608.209-2.76 1.614-2.76 3.235v6.226c0 1.621 1.152 3.026 2.76 3.235.577.075 1.157.14 1.74.194V21l4.155-4.155" />
                    </svg>
                    <span>Chat</span>
                </a>
            }

            @if (CurrentPage != "upload")
            {
                <!-- Upload ETL link -->
                <a href="/upload" class="analysis-nav-btn" title="Upload ETL Trace">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5"
                         stroke="currentColor" width="16" height="16">
                        <path stroke-linecap="round" stroke-linejoin="round"
                              d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5m-13.5-9L12 3m0 0l4.5 4.5M12 3v13.5" />
                    </svg>
                    <span>Upload</span>
                </a>
            }

            @if (CurrentPage != "traces")
            {
                <!-- Traces link -->
                <a href="/traces" class="analysis-nav-btn" title="Manage Traces">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5"
                         stroke="currentColor" width="16" height="16">
                        <path stroke-linecap="round" stroke-linejoin="round"
                              d="M20.25 6.375c0 2.278-3.694 4.125-8.25 4.125S3.75 8.653 3.75 6.375m16.5 0c0-2.278-3.694-4.125-8.25-4.125S3.75 4.097 3.75 6.375m16.5 0v11.25c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125V6.375m16.5 0v3.75m-16.5-3.75v3.75m16.5 0v3.75C20.25 16.153 16.556 18 12 18s-8.25-1.847-8.25-4.125v-3.75m16.5 0c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125" />
                    </svg>
                    <span>Traces</span>
                </a>
            }

            <button class="switch-agent-btn" @onclick="@OnSwitchAgent" title="Switch agent">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="16" height="16" class="switch-agent-icon">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.325.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 011.37.49l1.296 2.247a1.125 1.125 0 01-.26 1.431l-1.003.827c-.293.241-.438.613-.43.992a7.723 7.723 0 010 .255c-.008.378.137.75.43.991l1.004.827c.424.35.534.955.26 1.43l-1.298 2.247a1.125 1.125 0 01-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.47 6.47 0 01-.22.128c-.331.183-.581.495-.644.869l-.213 1.281c-.09.543-.56.941-1.11.941h-2.594c-.55 0-1.019-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 01-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 01-1.369-.49l-1.297-2.247a1.125 1.125 0 01.26-1.431l1.004-.827c.292-.24.437-.613.43-.991a6.932 6.932 0 010-.255c.007-.38-.138-.751-.43-.992l-1.004-.827a1.125 1.125 0 01-.26-1.43l1.297-2.247a1.125 1.125 0 011.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.087.22-.128.332-.183.582-.495.644-.869l.214-1.28z" />
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                <span>Switch Agent</span>
            </button>

            @if (CurrentPage == "chat")
            {
                <button class="prompt-guide-btn" @onclick="@OnTogglePromptGuide" title="Prompt Guide">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="16" height="16">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
                    </svg>
                    <span>Guide</span>
                </button>

                <button class="new-chat-btn" @onclick="@OnNewChat" title="Start a new conversation">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="new-chat-icon">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
                    </svg>
                    <span>New Conversation</span>
                </button>
            }

            <!-- User Profile Section -->
            <AuthorizeView>
                <Authorized>
                    <div class="user-profile">
                        <div class="user-avatar" title="@GetUserEmail(context.User)">
                            @GetUserInitials(context.User)
                        </div>
                        <div class="user-info">
                            <span class="user-name">@GetUserDisplayName(context.User)</span>
                        </div>
                        <a href="Account/SignOut" class="sign-out-btn" title="Sign out">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0013.5 3h-6a2.25 2.25 0 00-2.25 2.25v13.5A2.25 2.25 0 007.5 21h6a2.25 2.25 0 002.25-2.25V15m3 0l3-3m0 0l-3-3m3 3H9" />
                            </svg>
                        </a>
                    </div>
                </Authorized>
            </AuthorizeView>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public EventCallback OnNewChat { get; set; }

    [Parameter]
    public bool ShowInformativeMessages { get; set; }

    [Parameter]
    public EventCallback OnToggleInformativeMessages { get; set; }

    [Parameter]
    public EventCallback OnSwitchAgent { get; set; }

    [Parameter]
    public EventCallback OnTogglePromptGuide { get; set; }

    [Parameter]
    public string? ActiveAgentName { get; set; }

    [Parameter]
    public string CurrentPage { get; set; } = "chat";

    private string GetUserDisplayName(ClaimsPrincipal user)
    {
        // Try different claim types for the display name
        return user.FindFirst("name")?.Value
            ?? user.FindFirst(ClaimTypes.Name)?.Value
            ?? user.FindFirst("preferred_username")?.Value
            ?? user.Identity?.Name
            ?? "User";
    }

    private string GetUserEmail(ClaimsPrincipal user)
    {
        return user.FindFirst("preferred_username")?.Value
            ?? user.FindFirst(ClaimTypes.Email)?.Value
            ?? user.FindFirst(ClaimTypes.Upn)?.Value
            ?? "";
    }

    private string GetUserInitials(ClaimsPrincipal user)
    {
        var name = GetUserDisplayName(user);

        if (string.IsNullOrEmpty(name) || name == "User")
            return "U";

        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);

        if (parts.Length >= 2)
            return $"{parts[0][0]}{parts[^1][0]}".ToUpper();

        return name.Length >= 2 ? name[..2].ToUpper() : name.ToUpper();
    }
}

{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "CopilotStudio": {
    "EnvironmentId": "<YOUR_COPILOT_STUDIO_ENVIRONMENT_ID>",
    "SchemaName": "<YOUR_COPILOT_STUDIO_SCHEMA_NAME>"
  },
  "AzureAd": {
    "Instance": "https://login.microsoftonline.com/",
    "TenantId": "<YOUR_ENTRA_TENANT_ID>",
    "ClientId": "<YOUR_ENTRA_CLIENT_ID>",
    "CallbackPath": "/signin-oidc",
    "SignedOutCallbackPath": "/signout-oidc"
  },
  "EtlImport": {
    "StorageConnectionString": "UseDevelopmentStorage=true",
    "ContainerName": "etl-uploads",
    "DabBaseUrl": "<YOUR_DAB_APP_SERVICE_URL>"
  },
  "AllowedHosts": "*"
}


